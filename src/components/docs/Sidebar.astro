---
const base = import.meta.env.BASE_URL;
const current = Astro.url.pathname.replace(/\/$/, "");

const links = [
  { href: `${base}docs`, label: "Introduction" },
  { href: `${base}docs/zero-day`, label: "What is a Zero-Day?" },
  { href: `${base}docs/lifecycle`, label: "Lifecycle" },
  { href: `${base}docs/case-studies`, label: "Case Studies" },
  { href: `${base}docs/linux-security`, label: "Linux Security" },
  { href: `${base}docs/references`, label: "References" }
];
---

<aside class="sidebar">

<h2>Documentation</h2>

<nav>

{
links.map(link => (

<a
href={link.href}
class={current === link.href ? "active" : ""}
>
{link.label}
</a>

))
}

</nav>

</aside>

<style>

.sidebar{
    width:240px;
    flex-shrink:0;
    padding:3rem 1.5rem;
    border-right:1px solid var(--line);
    min-height:calc(100vh - 64px);
    position:sticky;
    top:64px;
}

.sidebar h2{
    font-family:'IBM Plex Mono', monospace;
    font-size:.75rem;
    font-weight:500;
    text-transform:uppercase;
    letter-spacing:.06em;
    color:var(--muted);
    margin-bottom:1.25rem;
}

.sidebar nav{
    display:flex;
    flex-direction:column;
    gap:.15rem;
}

.sidebar a{
    text-decoration:none;
    color:var(--ink-soft);
    font-size:.92rem;
    padding:.55rem .75rem;
    border-radius:var(--radius);
    border-left:2px solid transparent;
    transition:.15s ease;
}

.sidebar a:hover{
    background:var(--bg-alt);
    color:var(--accent);
}

.active{
    background:var(--accent-soft);
    color:var(--accent) !important;
    border-left:2px solid var(--accent);
    font-weight:500;
}

@media(max-width:900px){

.sidebar{
    display:none;
}

}

</style>
