---
const current = Astro.url.pathname;

const links = [
  { href: "/docs", label: "📘 Introduction" },
  { href: "/docs/zero-day", label: "🛡️ What is a Zero-Day?" },
  { href: "/docs/lifecycle", label: "🔄 Lifecycle" },
  { href: "/docs/case-studies", label: "💥 Case Studies" },
  { href: "/docs/linux-security", label: "🐧 Linux Security" },
  { href: "/docs/references", label: "📚 References" }
];
---

<aside class="sidebar">

<h2>Documentation</h2>

<nav>

{
links.map(link => (

<a
href={link.href}
class={current === link.href ? "active" : ""}
>
{link.label}
</a>

))
}

</nav>

</aside>

<style>

.sidebar{
    width:260px;
    padding:2rem;
    border-right:1px solid #30363d;
    min-height:calc(100vh - 72px);
    position:sticky;
    top:72px;
}

.sidebar nav{
    display:flex;
    flex-direction:column;
    gap:.5rem;
}

.sidebar a{
    text-decoration:none;
    color:#9da7b3;
    padding:.8rem 1rem;
    border-radius:10px;
    transition:.25s;
}

.sidebar a:hover{
    background:#161b22;
    color:#58a6ff;
}

.active{
    background:#1f2937;
    color:#58a6ff !important;
    border-left:3px solid #58a6ff;
}

@media(max-width:900px){

.sidebar{
display:none;
}

}

</style>