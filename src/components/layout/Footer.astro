---
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container footer-content">

    <div>
      <h3>Zero-Day Handbook</h3>
      <p>
        An open-source educational project explaining zero-day
        vulnerabilities through real-world examples.
      </p>
    </div>

    <div class="links">
      <a href={base}>Home</a>
      <a href={`${base}docs`}>Documentation</a>
      <a href="https://github.com/mavirudra/zero-day" target="_blank" rel="noopener">
        GitHub
      </a>
    </div>

  </div>

  <div class="container copyright">
    <span>© 2026 Zero-Day Handbook</span>
    <span>open source · MIT licensed</span>
  </div>
</footer>

<style>
.footer{
    margin-top:4rem;
    border-top:1px solid var(--line);
    padding:3rem 0 1.5rem;
}

.footer-content{
    display:flex;
    justify-content:space-between;
    gap:3rem;
    flex-wrap:wrap;
}

.footer h3{
    font-size:1.1rem;
    margin-bottom:.8rem;
}

.footer p{
    color:var(--ink-soft);
    max-width:380px;
    line-height:1.7;
    font-size:.95rem;
}

.links{
    display:flex;
    flex-direction:column;
    gap:.7rem;
}

.links a{
    font-family:'IBM Plex Mono', monospace;
    font-size:.85rem;
    color:var(--ink-soft);
    text-decoration:none;
    width:fit-content;
    border-bottom:1px solid transparent;
}

.links a:hover{
    color:var(--accent);
    border-color:var(--accent);
}

.copyright{
    margin-top:2.5rem;
    display:flex;
    justify-content:space-between;
    font-family:'IBM Plex Mono', monospace;
    color:var(--muted);
    font-size:.75rem;
}

@media(max-width:500px){
.copyright{
    flex-direction:column;
    gap:.4rem;
}
}
</style>
