---
const base = import.meta.env.BASE_URL;
---

<header class="navbar">

  <div class="container nav">

    <a href={base} class="logo">
      zero-day<strong>.</strong>
    </a>

    <nav>

      <a href={base}>home</a>

      <a href={`${base}docs`}>docs</a>

      <a href={`${base}#learn`}>learn</a>

      <a href="https://github.com/mavirudra/zero-day"
         target="_blank" rel="noopener">
         github
      </a>

    </nav>

  </div>

</header>

<style>

.navbar{
    position:sticky;
    top:0;
    z-index:1000;
    backdrop-filter:blur(6px);
    background:rgba(250,250,248,.88);
    border-bottom:1px solid var(--line);
}

.nav{
    height:64px;
    display:flex;
    align-items:center;
    justify-content:space-between;
}

.logo{
    font-family:'IBM Plex Mono', monospace;
    font-size:.9rem;
    letter-spacing:.02em;
    color:var(--ink);
}

.logo strong{
    color:var(--accent);
}

nav{
    display:flex;
    gap:1.75rem;
}

nav a{
    font-family:'IBM Plex Mono', monospace;
    font-size:.8rem;
    text-decoration:none;
    color:var(--ink-soft);
    padding-bottom:4px;
    border-bottom:1px solid transparent;
    transition:.15s ease;
}

nav a:hover{
    color:var(--accent);
    border-color:var(--accent);
}

@media(max-width:768px){

nav{
    display:none;
}

}

</style>
