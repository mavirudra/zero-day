---
interface Props {
  idx: string;
  title: string;
  description: string;
}

const { idx, title, description } = Astro.props;
---

<div class="step">
  <div class="idx">{idx}</div>

  <div>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
.step{
    padding:1.5rem 0;
    border-top:1px solid var(--line);
    display:grid;
    grid-template-columns:70px 1fr;
    gap:1.25rem;
    align-items:baseline;
}

.step:first-of-type{
    border-top:none;
}

.step .idx{
    font-family:'IBM Plex Mono', monospace;
    color:var(--muted);
    font-size:.85rem;
}

.step h3{
    font-size:1.15rem;
    margin-bottom:.4rem;
}

.step p{
    color:var(--ink-soft);
    max-width:520px;
    line-height:1.6;
}

@media(max-width:600px){
.step{
    grid-template-columns:1fr;
    gap:.4rem;
}
}
</style>
