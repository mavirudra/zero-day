---
interface Props {
  emoji: string;
  title: string;
  description: string;
}

const { emoji, title, description } = Astro.props;
---

<div class="step">
  <div class="emoji">{emoji}</div>

  <h3>{title}</h3>

  <p>{description}</p>
</div>

<style>
.step{
    background:#161b22;
    border:1px solid #30363d;
    border-radius:18px;
    padding:2rem;
    transition:.3s;
    position:relative;
}

.step:hover{
    transform:translateY(-8px);
    border-color:#58a6ff;
    box-shadow:0 0 25px rgba(88,166,255,.18);
}

.emoji{
    font-size:2.2rem;
    margin-bottom:1rem;
}

.step h3{
    margin-bottom:.7rem;
}

.step p{
    color:#9da7b3;
    line-height:1.6;
}
</style>