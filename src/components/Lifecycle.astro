---
import LifecycleStep from "./LifecycleStep.astro";
---

<section class="lifecycle">

<div class="section-head">
  <span class="tag">03</span>
  <h2>Vulnerability Lifecycle</h2>
</div>

<p class="intro">
Every zero-day follows a journey — from discovery by researchers to
exploitation by attackers and eventually a security patch.
</p>

<div class="timeline">

<LifecycleStep
idx="01"
title="Discovery"
description="A software flaw is discovered by a researcher or attacker."
/>

<LifecycleStep
idx="02"
title="Analysis"
description="The vulnerability is analyzed to understand its impact."
/>

<LifecycleStep
idx="03"
title="Exploitation"
description="Attackers may create malware or exploits before a fix exists."
/>

<LifecycleStep
idx="04"
title="Disclosure"
description="The issue is reported responsibly to the software vendor."
/>

<LifecycleStep
idx="05"
title="Patch"
description="The vendor releases an update to fix the vulnerability."
/>

</div>

</section>

<style>
.lifecycle{
    padding:5rem 0;
}

.section-head{
    display:flex;
    align-items:baseline;
    gap:.75rem;
    margin-bottom:.75rem;
}

.section-head .tag{
    font-family:'IBM Plex Mono', monospace;
    font-size:.8rem;
    color:var(--muted);
}

.section-head h2{
    font-size:clamp(1.75rem,4vw,2.25rem);
}

.intro{
    max-width:600px;
    color:var(--ink-soft);
    margin-bottom:2.5rem;
}

.timeline{
    display:flex;
    flex-direction:column;
}
</style>
