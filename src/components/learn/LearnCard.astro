---
interface Props {
  icon: any;
  title: string;
  description: string;
}

const { icon: Icon, title, description } = Astro.props;
---

<div class="learn-card">
  <div class="icon">
    <Icon size={36} strokeWidth={2} />
  </div>

  <h3>{title}</h3>

  <p>{description}</p>
</div>

<style>
.learn-card {
  background: #161b22;
  border: 1px solid #30363d;
  border-radius: 18px;
  padding: 2rem;
  transition: all .3s ease;
}

.learn-card:hover {
  transform: translateY(-8px);
  border-color: #58a6ff;
  box-shadow: 0 0 30px rgba(88,166,255,.15);
}

.icon{
  color:#58a6ff;
  margin-bottom:1rem;
}

.learn-card h3{
  margin-bottom:.8rem;
}

.learn-card p{
  color:#9da7b3;
  line-height:1.7;
}
</style>