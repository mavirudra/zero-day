---
interface Props {
  icon: any;
  index: string;
  title: string;
  description: string;
}

const { icon: Icon, index, title, description } = Astro.props;
---

<div class="learn-card">
  <div class="card-top">
    <div class="icon">
      <Icon size={22} strokeWidth={1.75} />
    </div>
    <span class="idx">{index}</span>
  </div>

  <h3>{title}</h3>

  <p>{description}</p>
</div>

<style>
.learn-card {
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 1.6rem;
  transition: border-color .2s ease;
}

.learn-card:hover {
  border-color: var(--accent);
}

.card-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:1.1rem;
}

.icon{
  width:38px;
  height:38px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:50%;
  background:var(--accent-soft);
  color:var(--accent);
}

.idx{
  font-family:'IBM Plex Mono', monospace;
  font-size:.75rem;
  color:var(--muted);
}

.learn-card h3{
  font-size:1.05rem;
  margin-bottom:.6rem;
}

.learn-card p{
  color:var(--ink-soft);
  line-height:1.65;
  font-size:.92rem;
}
</style>
