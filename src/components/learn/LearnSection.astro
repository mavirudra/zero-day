---
import LearnCard from "./LearnCard.astro";
import { Shield, Bug, Terminal, Brain } from "lucide-astro";
---

<section id="learn" class="learn-section">

<h2>What You'll Learn</h2>

<p class="section-text">
This handbook explains how zero-day vulnerabilities are discovered,
weaponized, and defended against using real-world examples.
</p>

<div class="grid">

<LearnCard
  icon={Shield}
  title="Zero-Day Basics"
  description="Understand what zero-day vulnerabilities are and why they are among the most critical cybersecurity threats."
/>

<LearnCard
  icon={Bug}
  title="Famous Attacks"
  description="Explore incidents like Stuxnet, Pegasus, and other exploits that changed cybersecurity."
/>

<LearnCard
  icon={Terminal}
  title="Linux Security"
  description="Learn why Linux powers critical infrastructure and how vulnerabilities affect it."
/>

<LearnCard
  icon={Brain}
  title="Defense"
  description="Discover how researchers detect, disclose, and mitigate zero-day vulnerabilities."
/>

</div>

</section>

<style>

.learn-section{

padding:7rem 0;

}

.learn-section h2{

font-size:3rem;

text-align:center;

margin-bottom:1rem;

}

.section-text{

max-width:700px;

margin:auto;

text-align:center;

margin-bottom:4rem;

color:#9da7b3;

}

.grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

gap:2rem;

}

</style>