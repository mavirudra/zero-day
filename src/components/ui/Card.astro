---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="card">

  {title && <h3>{title}</h3>}

  <slot />

</div>

<style>

.card{
    background:#161b22;
    border:1px solid #30363d;
    border-radius:18px;
    padding:1.5rem;
    transition:.25s;
}

.card:hover{
    transform:translateY(-4px);
    border-color:#58a6ff;
    box-shadow:0 0 20px rgba(88,166,255,.15);
}

.card h3{
    margin-bottom:1rem;
}

</style>