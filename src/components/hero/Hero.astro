---
const base = import.meta.env.BASE_URL;
---

<section class="hero">

  <div class="container hero-grid">

    <div class="hero-content">

      <span class="eyebrow">
        <span class="dot"></span> CYBERSECURITY HANDBOOK · 2026
      </span>

      <h1 class="name">
        Understanding<br />
        <em>Zero-Day</em> Vulnerabilities
      </h1>

      <p class="subtitle">
        A modern, beginner-friendly handbook explaining how zero-day
        vulnerabilities are discovered, exploited, and patched — through
        real-world examples and security research.
      </p>

      <div class="terminal">
        <span class="prompt">$</span><span class="typed" id="typedLine">scan --target unknown</span>
      </div>

      <div class="cta-row">
        <a href={`${base}docs`} class="btn solid">
          Read Docs
        </a>

        <a
          href="https://github.com/mavirudra/zero-day"
          target="_blank"
          rel="noopener"
          class="btn ghost"
        >
          View Source
        </a>
      </div>

      <div class="stats">
        <div>
          <h3>5+</h3>
          <p>Case Studies</p>
        </div>

        <div>
          <h3>12 min</h3>
          <p>Reading Time</p>
        </div>

        <div>
          <h3>Open</h3>
          <p>Source</p>
        </div>
      </div>

    </div>

    <div class="hero-panel">

      <div class="panel-card">
        <span class="idx">01</span>
        <div>
          <h3>Fundamentals</h3>
          <p>Understand what zero-day vulnerabilities are and why they matter.</p>
        </div>
      </div>

      <div class="panel-card">
        <span class="idx">02</span>
        <div>
          <h3>Case Studies</h3>
          <p>Explore famous incidents including Stuxnet and Pegasus.</p>
        </div>
      </div>

      <div class="panel-card">
        <span class="idx">03</span>
        <div>
          <h3>Linux Security</h3>
          <p>Learn how vulnerabilities affect Linux servers and operating systems.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
.hero{
    padding:6rem 0 5rem;
}

.hero-grid{
    display:grid;
    grid-template-columns:1.2fr 1fr;
    gap:4rem;
    align-items:center;
}

.hero-content{
    z-index:2;
}

.eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:.8rem;
    color:var(--accent);
    display:flex;
    align-items:center;
    gap:.5rem;
    margin-bottom:1.5rem;
    letter-spacing:.04em;
}

.dot{
    width:7px;
    height:7px;
    border-radius:50%;
    background:var(--accent);
    display:inline-block;
}

.name{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:clamp(2.6rem,6vw,4rem);
    line-height:1.08;
    margin-bottom:1.25rem;
    letter-spacing:-.01em;
}

.name em{
    font-style:normal;
    color:var(--accent);
}

.subtitle{
    color:var(--ink-soft);
    font-size:1.1rem;
    line-height:1.8;
    max-width:560px;
    margin-bottom:2rem;
}

.terminal{
    font-family:'IBM Plex Mono', monospace;
    font-size:.9rem;
    background:var(--ink);
    color:#D7E4DC;
    border-radius:var(--radius);
    padding:14px 18px;
    max-width:400px;
    overflow:hidden;
}

.terminal .prompt{
    color:#7FBFA1;
    margin-right:8px;
}

.terminal .typed::after{
    content:'';
    display:inline-block;
    width:6px;
    height:14px;
    background:#7FBFA1;
    margin-left:2px;
    vertical-align:-2px;
    animation:blink 1s step-end infinite;
}

@keyframes blink{
    50%{ opacity:0; }
}

.cta-row{
    display:flex;
    gap:1rem;
    margin-top:2rem;
    flex-wrap:wrap;
}

.stats{
    display:flex;
    gap:2.5rem;
    margin-top:3rem;
    flex-wrap:wrap;
}

.stats h3{
    font-family:'Fraunces', serif;
    font-size:1.6rem;
    margin-bottom:.2rem;
}

.stats p{
    font-family:'IBM Plex Mono', monospace;
    font-size:.75rem;
    color:var(--muted);
    text-transform:uppercase;
    letter-spacing:.04em;
}

.hero-panel{
    display:flex;
    flex-direction:column;
    gap:1rem;
}

.panel-card{
    display:grid;
    grid-template-columns:32px 1fr;
    gap:.75rem;
    background:var(--bg);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:1.4rem 1.5rem;
    transition:.2s ease;
}

.panel-card:hover{
    border-color:var(--accent);
}

.panel-card .idx{
    font-family:'IBM Plex Mono', monospace;
    font-size:.8rem;
    color:var(--muted);
}

.panel-card h3{
    font-size:1.05rem;
    margin-bottom:.4rem;
}

.panel-card p{
    color:var(--ink-soft);
    line-height:1.6;
    font-size:.92rem;
}

@media(max-width:900px){

.hero{
    padding:4rem 0;
}

.hero-grid{
    grid-template-columns:1fr;
}

.cta-row{
    justify-content:flex-start;
}

.stats{
    justify-content:flex-start;
}

}
</style>

<script>
  const target = "scan --target unknown";
  const el = document.getElementById('typedLine');
  if (el) {
    el.textContent = '';
    let i = 0;
    function type(){
      if(i <= target.length){
        el.textContent = target.slice(0, i);
        i++;
        setTimeout(type, 90);
      }
    }
    window.addEventListener('load', () => setTimeout(type, 400));
  }
</script>
